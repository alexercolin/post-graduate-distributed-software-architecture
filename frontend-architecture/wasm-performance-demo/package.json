{
  "name": "wasm-performance-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "asbuild": "asc assembly/index.ts --outFile public/wasm/module.wasm --textFile public/wasm/module.wat --optimize --runtime stub --exportStart",
    "dev": "npm run asbuild && vite",
    "build": "npm run asbuild && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "assemblyscript": "^0.27.32",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  }
}
